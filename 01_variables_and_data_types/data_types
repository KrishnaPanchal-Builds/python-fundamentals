"""
Python Data Types Showcase
Author: Krishna Panchal

This program demonstrates the major built-in Python data types
and their practical usage.
"""

# Numeric Types
integer_value = 100
float_value = 99.99
complex_value = 4 + 7j

# Boolean
is_learning = True

# String
name = "Krishna Panchal"

# Sequence Types
programming_languages = ["Python", "SQL", "Java"]           # List
ai_roadmap = ("Python", "ML", "DL", "LLMs")                # Tuple
learning_path = range(1, 6)                                # Range

# Mapping Type
student_profile = {
    "name": "Krishna",
    "goal": "AI Engineer",
    "experience_level": "Beginner"
}

# Set Types
skills = {"Python", "Git", "SQL"}                          # Set
frozen_skills = frozenset({"Python", "Git", "SQL"})        # Frozen Set

# Binary Types
binary_data = b"AI"
byte_array_data = bytearray(b"Machine Learning")
memory_view_data = memoryview(bytes(5))

print("=" * 60)
print("PYTHON DATA TYPES SHOWCASE")
print("=" * 60)

data_types = {
    "Integer": integer_value,
    "Float": float_value,
    "Complex": complex_value,
    "Boolean": is_learning,
    "String": name,
    "List": programming_languages,
    "Tuple": ai_roadmap,
    "Range": learning_path,
    "Dictionary": student_profile,
    "Set": skills,
    "Frozen Set": frozen_skills,
    "Bytes": binary_data,
    "Bytearray": byte_array_data,
    "Memoryview": memory_view_data
}

for data_type, value in data_types.items():
    print(f"\n{data_type}")
    print("-" * 30)
    print(f"Value : {value}")
    print(f"Type  : {type(value)}")

print("\n" + "=" * 60)
print("SUMMARY")
print("=" * 60)

print(f"Total Data Types Demonstrated: {len(data_types)}")
print("All major built-in Python data types covered successfully.")
